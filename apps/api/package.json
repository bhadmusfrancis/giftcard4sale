{
  "name": "@gc4s/api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --import ./scripts/sync-noones-preload.ts src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "seed:landing": "tsx scripts/seed-landing-articles.ts",
    "publish:landing": "tsx scripts/publish-landing-pages.ts",
    "import:noones-cards": "tsx scripts/import-noones-cards.ts",
    "sync:noones": "tsx --import ./scripts/sync-noones-preload.ts scripts/sync-noones.ts",
    "sync:noones-rates": "tsx --import ./scripts/sync-noones-preload.ts scripts/sync-noones.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.682.0",
    "@gc4s/shared": "*",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.16",
    "tweetnacl": "^1.0.3",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "@types/web-push": "^3.6.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  }
}
