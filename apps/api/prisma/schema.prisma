generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum CardMedium {
  PHYSICAL
  ECODE
}

enum ReceiptType {
  NONE
  CASH
  DEBIT
}

enum PayoutCurrency {
  USDT
  NGN
  GHS
}

enum TradeStatus {
  PENDING
  PROCESSING
  INFO_REQUESTED
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  PAID
}

enum TxnType {
  TRADE_CREDIT
  WITHDRAWAL_DEBIT
  TRANSFER_DEBIT
  TRANSFER_CREDIT
  REFERRAL_BONUS
  ADMIN_ADJUSTMENT
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  displayName       String?
  avatarUrl         String?
  role              UserRole @default(USER)

  emailVerified     Boolean  @default(false)
  verifyToken       String?
  verifyTokenExp    DateTime?
  resetToken        String?
  resetTokenExp     DateTime?
  passwordChangedAt DateTime?

  accountStatus     AccountStatus @default(ACTIVE)
  suspendedUntil    DateTime?
  suspensionReason  String?
  maxConcurrentTrades Int?
  adminNotes        String?

  // reputation
  goodScore         Int      @default(0)
  badScore          Int      @default(0)
  trustLevel        Int      @default(1)

  // wallet balances (kept as Decimal for money math)
  balanceUsdt       Decimal  @default(0) @db.Decimal(20, 6)
  balanceNgn        Decimal  @default(0) @db.Decimal(20, 2)
  balanceGhs        Decimal  @default(0) @db.Decimal(20, 2)

  // referral
  referralCode      String   @unique
  referredById      String?
  referredBy        User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]   @relation("Referrals")

  // push subscriptions (JSON array of PushSubscription)
  pushSubscriptions PushSubscription[]

  bankAccounts      BankAccount[]
  momoAccounts      MomoAccount[]
  trades            Trade[]
  withdrawals       Withdrawal[]
  transactions      WalletTransaction[]
  referralEarnings  ReferralEarning[]  @relation("Earner")
  generatedEarnings ReferralEarning[]  @relation("Source")
  notifications     Notification[]
  sentMessages      TradeMessage[]
  moderationEvents  UserModerationEvent[]
  moderationActions UserModerationEvent[] @relation("ModerationAdmin")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model CardType {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "Apple/iTunes"
  slug        String   @unique // e.g. "apple-itunes"
  sellSlug    String   @unique // e.g. "sell-apple-itunes-gift-card"
  // NoOnes payment-method slug (e.g. amazon-gift-card). Auto-guessed when blank.
  noonesPaymentMethod String?
  description String?
  imageUrl    String?
  active      Boolean  @default(true)
  // Cached NoOnes buy-offer count for catalog popularity sorting.
  offerCount  Int      @default(0)
  // Sum of completed trades across NoOnes offers (catalog tie-breaker).
  tradeVolume Int      @default(0)
  rates       Rate[]
  currencyMeta CardCurrencyMeta[]
  trades      Trade[]
  landingPage LandingPage?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Rate {
  id            String     @id @default(cuid())
  cardType      CardType   @relation(fields: [cardTypeId], references: [id], onDelete: Cascade)
  cardTypeId    String
  country       String
  currency      String // face currency of the card, e.g. USD, GBP
  minDenom      Int?
  maxDenom      Int?
  medium        CardMedium @default(PHYSICAL)
  nairaPerUnit  Decimal    @db.Decimal(20, 4) // SLOW base rate, NGN per unit
  storedQuotes  Json?      // Cached NoOnes variants: NONE, CASH, DEBIT (per medium row)
  countryOfferCount Int?   // Cached NoOnes offers for this country/currency tier
  speed         String? // SLOW | FAST (kept for audit)
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([cardTypeId, country, medium])
}

// Cached NoOnes offer metadata per card currency (ranges, offer count).
model CardCurrencyMeta {
  id          String   @id @default(cuid())
  cardType    CardType @relation(fields: [cardTypeId], references: [id], onDelete: Cascade)
  cardTypeId  String
  country     String
  currency    String
  offerCount  Int      @default(0)
  denomRanges Json     @default("[]") // [{ min, max }, ...] from NoOnes offers
  syncedAt    DateTime @default(now())

  @@unique([cardTypeId, currency])
  @@index([cardTypeId])
}

// Live exchange rates + reduction config, single editable row (latest wins).
model RateConfig {
  id                    String   @id @default(cuid())
  ngnPerUsdt            Decimal  @db.Decimal(20, 4)
  ngnPerGhs             Decimal  @db.Decimal(20, 4)
  nairaReductionPercent Int      @default(20)
  usdtReductionPercent  Int      @default(30)
  ghsReductionPercent   Int      @default(30)
  referralPercent       Int      @default(1)
  noonesRateRefreshHours   Int   @default(1)
  noonesTopOffersForRate   Int   @default(3)
  minCountryOffersForDisplay Int @default(5)
  defaultMaxConcurrentTrades Int @default(5)
  autoSuspendRejectThreshold Int @default(5)
  autoSuspendRejectWindowDays Int @default(30)
  autoSuspendDurationDays    Int @default(7)
  minWithdrawalNgn          Decimal @default(5000) @db.Decimal(20, 2)
  minWithdrawalGhs          Decimal @default(50) @db.Decimal(20, 2)
  minWithdrawalUsdt         Decimal @default(5) @db.Decimal(20, 6)
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())
}

model Trade {
  id              String         @id @default(cuid())
  tradeNumber     String         @unique // Human-readable ID, e.g. GC4S-20260620-A1B2C3
  user            User           @relation(fields: [userId], references: [id])
  userId          String
  cardType        CardType       @relation(fields: [cardTypeId], references: [id])
  cardTypeId      String

  country         String
  otherCountryName String?
  currency        String
  medium          CardMedium
  receiptType     ReceiptType    @default(NONE)
  cardAmount      Decimal        @db.Decimal(20, 2) // face value in card currency
  cardDenominations String?
  payoutCurrency  PayoutCurrency

  // Quote snapshot at creation time
  nairaPerUnit    Decimal        @db.Decimal(20, 4)
  effectiveRate   Decimal        @db.Decimal(20, 6)
  quotedPayout    Decimal        @db.Decimal(20, 6)

  // What is actually paid (admin can adjust)
  finalPayout     Decimal?       @db.Decimal(20, 6)

  status          TradeStatus    @default(PENDING)
  ecodes          String? // pasted codes (for ECODE trades)
  notes           String?
  rejectionReason String?

  // NoOnes P2P resell (hidden from end users)
  noonesTradeHash     String?  @unique
  noonesOfferHash     String?
  noonesStatus        String?
  noonesError         String?
  noonesCryptoAmount  Decimal? @db.Decimal(20, 8)
  noonesCryptoCurrency String?
  noonesAwaitingSend  Boolean  @default(false)

  attachments     TradeAttachment[]
  messages        TradeMessage[]
  transaction     WalletTransaction?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, status])
  @@index([noonesTradeHash])
}

model NoOnesWebhookEvent {
  id         String   @id @default(cuid())
  eventType  String
  tradeHash  String?
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([eventType, tradeHash])
  @@index([tradeHash])
}

model TradeAttachment {
  id        String   @id @default(cuid())
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tradeId   String
  url       String
  filename  String
  createdAt DateTime @default(now())
}

model TradeMessage {
  id        String   @id @default(cuid())
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tradeId   String
  sender    User     @relation(fields: [senderId], references: [id])
  senderId  String
  body      String   @default("")
  attachmentUrl      String?
  attachmentFilename String?
  attachmentMimeType String?
  createdAt DateTime @default(now())

  @@index([tradeId])
}

model BankAccount {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  bankName      String
  accountNumber String
  accountName   String
  withdrawals   Withdrawal[]
  createdAt     DateTime @default(now())

  @@index([userId])
}

model MomoAccount {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  network       String
  phoneNumber   String
  accountName   String
  withdrawals   Withdrawal[]
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("MoMoAccount")
}

model Withdrawal {
  id             String           @id @default(cuid())
  user           User             @relation(fields: [userId], references: [id])
  userId         String
  currency       PayoutCurrency
  amount         Decimal          @db.Decimal(20, 6)

  // Destination: NGN -> bank account; GHS -> MoMo; USDT -> wallet address
  bankAccountId  String?
  bankAccount    BankAccount? @relation(fields: [bankAccountId], references: [id])
  momoAccountId  String?
  momoAccount    MomoAccount? @relation(fields: [momoAccountId], references: [id])
  destinationAddress String?

  status         WithdrawalStatus @default(PENDING)
  adminNote      String?
  transaction    WalletTransaction?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId, status])
}

model UserModerationEvent {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  admin          User?    @relation("ModerationAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  adminId        String?
  action         String
  reason         String?
  suspendedUntil DateTime?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

model WalletTransaction {
  id           String         @id @default(cuid())
  user         User           @relation(fields: [userId], references: [id])
  userId       String
  type         TxnType
  currency     PayoutCurrency
  amount       Decimal        @db.Decimal(20, 6) // positive = credit, negative = debit
  balanceAfter Decimal        @db.Decimal(20, 6)
  description  String?

  tradeId      String?        @unique
  trade        Trade?         @relation(fields: [tradeId], references: [id])
  withdrawalId String?        @unique
  withdrawal   Withdrawal?    @relation(fields: [withdrawalId], references: [id])

  createdAt    DateTime       @default(now())

  @@index([userId, createdAt])
}

model ReferralEarning {
  id           String   @id @default(cuid())
  earner       User     @relation("Earner", fields: [earnerId], references: [id])
  earnerId     String
  source       User     @relation("Source", fields: [sourceId], references: [id])
  sourceId     String
  currency     PayoutCurrency
  amount       Decimal  @db.Decimal(20, 6)
  description  String?
  createdAt    DateTime @default(now())

  @@index([earnerId])
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// SEO landing pages rewritten from Facebook posts.
model LandingPage {
  id           String    @id @default(cuid())
  slug         String    @unique // e.g. "sell-lowes-gift-card"
  title        String
  metaTitle    String?
  metaDesc     String?
  bodyHtml     String // rewritten post content
  cardType     CardType? @relation(fields: [cardTypeId], references: [id])
  cardTypeId   String?   @unique
  sourceUrl    String? // original facebook post url (for reference)
  published    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
