# ---------------------------------------------------------------------------
# GiftCard4Sale environment. Copy to ".env" (root) and to apps/api/.env
# ---------------------------------------------------------------------------

# --- Database ---
# Option A: local Postgres via docker-compose (npm run db:up)
DATABASE_URL="postgresql://gc4s:gc4s_password@localhost:5432/gc4s?schema=public"
#
# Option B (recommended): a FREE hosted Postgres. Replace the line above with the
# connection string from your provider. Hosted DBs require SSL, so keep sslmode=require.
#   Neon:     postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/gc4s?sslmode=require
#   Supabase: postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres?sslmode=require
#   Railway:  postgresql://postgres:PASSWORD@containers-xxx.railway.app:1234/railway?sslmode=require

# --- API server ---
API_PORT=4000
# Public URL of the API (used in emails / uploads)
API_URL="http://localhost:4000"
# Public URL of the web app (used in verification + notification links)
WEB_URL="http://localhost:3000"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Email (SMTP). Defaults point at the local Mailpit container above. ---
# For production, use a real provider. Common presets (set host/port/user/pass):
#   Resend:   host=smtp.resend.com   port=465 secure=true  user=resend           pass=<API key>
#   Brevo:    host=smtp-relay.brevo.com port=587 secure=false user=<login>        pass=<SMTP key>
#   SES:      host=email-smtp.<region>.amazonaws.com port=587 secure=false user=<SMTP user> pass=<SMTP pass>
#   Postmark: host=smtp.postmarkapp.com port=587 secure=false user=<token>        pass=<token>
#   Gmail:    host=smtp.gmail.com    port=465 secure=true  user=<you@gmail.com>   pass=<App Password>
# Always verify your sending domain (SPF/DKIM/DMARC) so emails don't go to spam.
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
MAIL_FROM="GiftCard4Sale <no-reply@giftcard4sale.com>"
# Brevo HTTP API (required on Render — outbound SMTP is blocked). Get from Brevo → SMTP & API → API keys.
BREVO_API_KEY=""

# --- Web Push (VAPID). Generate with: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@giftcard4sale.com"

# --- Exchange rates (fallbacks used when no live feed is configured) ---
# Naira per 1 USDT
RATE_NGN_PER_USDT=1650
# Naira per 1 GHS (Cedi)
RATE_NGN_PER_GHS=110

# --- Rate engine reductions (percent) ---
NAIRA_REDUCTION_PERCENT=20
USDT_REDUCTION_PERCENT=30
GHS_REDUCTION_PERCENT=30
# Legacy fallback if USDT/GHS vars are unset:
# FX_REDUCTION_PERCENT=30

# --- Referral ---
REFERRAL_PERCENT=1

# --- Initial admin (created by seed) ---
ADMIN_EMAIL="admin@giftcard4sale.com"
ADMIN_PASSWORD="ChangeMe123!"
SUPPORT_EMAIL="support@giftcard4sale.com"

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===========================================================================
# Production settings
# ===========================================================================

# Set to "production" on your server. Enables strict checks (e.g. JWT_SECRET).
NODE_ENV="development"

# Extra allowed CORS origins (comma-separated). WEB_URL is always allowed.
# e.g. "https://www.giftcard4sale.com,https://giftcard4sale.com"
CORS_ORIGINS=""

# --- Object storage for uploads (S3 / Cloudflare R2 / Supabase) ---
# When S3_BUCKET is set, uploads go to the bucket instead of local disk.
S3_BUCKET=""
S3_REGION="us-east-1"
# Set S3_ENDPOINT for R2/Supabase/MinIO (leave blank for AWS S3):
#   R2:       https://<accountid>.r2.cloudflarestorage.com
#   Supabase: https://<project>.supabase.co/storage/v1/s3
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Public base URL to read objects (CDN or bucket public URL), e.g. https://cdn.giftcard4sale.com
S3_PUBLIC_URL=""
S3_FORCE_PATH_STYLE="false"

# --- Payout provider for withdrawals: manual | paystack | flutterwave ---
PAYOUT_PROVIDER="manual"
PAYSTACK_SECRET_KEY=""
FLUTTERWAVE_SECRET_KEY=""

# --- NoOnes P2P integration (hidden resell + live rates) ---
# Set NOONES_ENABLED=true after adding credentials from https://dev.noones.com
NOONES_ENABLED="false"
NOONES_CLIENT_ID=""
NOONES_CLIENT_SECRET=""
# Application ID from developer portal (for webhook registration)
NOONES_APPLICATION_ID=""
# Public webhook URL (must be HTTPS in production)
NOONES_WEBHOOK_URL=""
# Crypto received when reselling cards (USDT or BTC)
NOONES_CRYPTO_CURRENCY="USDT"
NOONES_API_BASE="https://api.noones.com/noones/v1"
NOONES_TOKEN_URL="https://auth.noones.com/oauth2/token"
NOONES_RATE_SYNC_MINUTES=5
NOONES_TRADE_POLL_MINUTES=2
# When NoOnes has no separate e-code offers, ECODE = PHYSICAL × this factor (0.88 = 12% lower)
NOONES_ECODE_RATE_FACTOR=0.88
